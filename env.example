# Скопируй этот файл в .env и заполни значения:  cp env.example .env

# === Telegram Bot (интерфейс) ===
# Токен бота от @BotFather
BOT_TOKEN=

# === Telegram MTProto (GramJS, для постинга сторис) ===
# api_id и api_hash с https://my.telegram.org
TG_API_ID=
TG_API_HASH=
# Строка сессии, полученная через `npm run login`
TG_STRING_SESSION=
# Username или ID канала для сторис от сообщества (например, @mychannel или -100...)
TG_CHANNEL=

# === VK ===
# Вариант 1 (рекомендуется): постоянный ключ доступа сообщества.
# Не привязан к IP и не протухает. Если задан — используется в приоритете,
# OAuth-токены и `npm run vk-login` не нужны.
# Где взять: сообщество → Управление → Настройки → Работа с API → Ключи доступа → Создать ключ
# (права: stories, управление сообществом).
VK_TOKEN=

# Вариант 2: пользовательский токен VK ID OAuth (используется, только если VK_TOKEN пуст).
# Получить через `npm run vk-login` (сохраняются в data/vk-tokens.json).
# Минус: токен привязан к IP, с которого выдан.
VK_CLIENT_ID=
VK_ACCESS_TOKEN=
VK_REFRESH_TOKEN=
VK_DEVICE_ID=

# ID сообщества (без знака минус)
VK_GROUP_ID=

# Таймауты vk-io в миллисекундах (необязательно).
# Заливка медиа: при AbortError на больших видео увеличь. По умолчанию 300000 (5 мин).
VK_UPLOAD_TIMEOUT_MS=
# API-вызовы VK. По умолчанию 90000 (90 сек).
VK_API_TIMEOUT_MS=

# === Прочее ===
# Кто может пользоваться ботом (Telegram user id через запятую). Пусто = все.
ALLOWED_USER_IDS=
# Часовой пояс для расписания (например, Asia/Krasnoyarsk)
TZ=Asia/Krasnoyarsk
